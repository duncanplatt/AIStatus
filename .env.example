# API keys for active probing (all optional — official status works without them)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# Shown in probe tooltips (optional). On Vercel, VERCEL_REGION is set automatically and
# mapped to a city/region name; use this to override (e.g. local dev) or for a custom label.
# CHECK_ORIGIN_LABEL=My homelab (local)

# CORS: comma-separated list of allowed origins (optional — omit to allow all)
# ALLOWED_ORIGINS=https://aistatus.net,https://www.aistatus.net
